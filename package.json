{
  "name": "agentic-workspace",
  "version": "0.0.4",
  "description": "AI-powered code review, pattern aggregation, rule evolution and metrics toolkit for engineering teams",
  "license": "MIT",
  "author": "Milo <milobluebell>",
  "repository": {
    "type": "git",
    "url": "https://github.com/milobluebell/agentic-workspace.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./src/*": {
      "types": "./dist/src/*.d.ts",
      "require": "./dist/src/*.js",
      "default": "./dist/src/*.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "aw-review": "dist/bin/aw-review.js",
    "aw-patterns": "dist/bin/aw-patterns.js",
    "aw-evolve": "dist/bin/aw-evolve.js",
    "aw-metrics": "dist/bin/aw-metrics.js",
    "aw-ask": "dist/bin/aw-ask.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}